nextflow_workflow {

    name "Test Subworkflow ISOFORM_QUANTIFICATION"
    script "../main.nf"
    workflow "ISOFORM_QUANTIFICATION"

    tag "subworkflows"
    tag "subworkflows_"
    tag "subworkflows/isoform_quantification"
    tag "samtools"
    tag "samtools/sort"
    tag "samtools/index"


    test("sarscov2 - bam - single_end") {

        when {
            workflow {
                """
                input[0] = [
                    [ id:'test', single_end:false ], // meta map
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.paired_end.sorted.bam', checkIfExists: true),
                ]
                input[1] = [
                    [ id:'genome' ],
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.paired_end.sorted.bam', checkIfExists: true),
                ]
                """
            }
        }
        then {
            assert workflow.success
            assertAll(
                { assert snapshot(
                    workflow.out
                ).match() }
            )
        }
    }
}

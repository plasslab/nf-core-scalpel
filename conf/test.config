/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config file for running minimal tests
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Defines input files and everything required to run a fast and simple pipeline test.

    Use as follows:
        nextflow run nf-core/scalpel -profile test,<docker/singularity> --outdir <OUTDIR>

----------------------------------------------------------------------------------------
*/

process {
    resourceLimits = [
        cpus: 7,
        memory: '11.GB',
        time: '1.h'
    ]
}

params {
    config_profile_name        = 'Test profile'
    config_profile_description = 'Minimal test dataset to check pipeline function'

    // Input data
    samplesheet   = "${projectDir}/subsample_data/samplesheet.csv"
    gtf           = "${projectDir}/subsample_data/annotations/reduced_GENCODE.vM21.annotation.gtf.gz"
    genome        = "${projectDir}/subsample_data/annotations/GRCm38.subset.genome.fa.gz"
    transcriptome = "${projectDir}/subsample_data/annotations/gencode.vM21.transcripts.fa.gz"
    ip_reference  = "${projectDir}/subsample_data/annotations/mm10_polya.track.gz"
}
